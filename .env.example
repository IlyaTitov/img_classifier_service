# Copy this file to .env and adjust values

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=img_classifier
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── Backend ───────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
BACKEND_PORT=8000

# Path to YOLOv8 weights inside the container (mounted via "weights" volume).
# Place yolov8s.pt in ./backend/src/weights/ on the host, it will be mounted
# at /app/weights/yolov8s.pt inside the container.
YOLO_MODEL_PATH=/app/weights/yolov8s.pt

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_PORT=80
